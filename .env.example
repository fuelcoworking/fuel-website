# Email delivery for the contact + free-day forms (via Resend).
# RESEND_API_KEY is required for any email to send.
# To deliver to your real inbox, verify the fuelcoworking.com domain in Resend
# and set CONTACT_EMAIL_FROM to an address on it (e.g. website@fuelcoworking.com).
RESEND_API_KEY=re_your_api_key_here
# Optional — defaults to info@fuelcoworking.com if unset.
CONTACT_EMAIL_TO=info@fuelcoworking.com
CONTACT_EMAIL_FROM=FUEL <onboarding@resend.dev>

# Optional: Google Maps Embed API key for Street View (otherwise uses a free embed)
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=

# Member Login button → your Proximity member portal URL
NEXT_PUBLIC_PROXIMITY_LOGIN_URL=https://app.proximity.space

# Eventbrite — powers the live events section
# Token: eventbrite.com → Account Settings → Developer Links → API keys → private token
EVENTBRITE_API_TOKEN=
EVENTBRITE_ORG_ID=110692675491

# Airtable — backend for the "Try a free day" trial signups
# Token: airtable.com/create/tokens (needs data.records:write on the base)
AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_NAME=Free Day Trials
